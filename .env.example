# AuraKit — Environment Variables
# Copy to .env and fill in values (never commit .env)

# GitHub API (optional — for star count on landing page)
# Not required; public API is used unauthenticated (rate limit: 60 req/hr)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Cloudflare Pages (set via wrangler or dashboard, not in code)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
